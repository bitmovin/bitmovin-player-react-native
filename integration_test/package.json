{
  "name": "bitmovin-player-react-native-integration-test",
  "main": "index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package",
    "bootstrap": "yarn install && yarn prebuild && yarn pods",
    "open:android": "open -a \"Android Studio\" android",
    "open:ios": "xed ios",
    "start": "expo start",
    "android": "expo run:android",
    "preios": "yarn patch-ios-build",
    "test": "yarn stop-test:android && yarn stop-test:ios && yarn start-test:android && yarn start-test:ios",
    "stop-packager": "./scripts/stop-packager.sh",
    "stop-test:android": "./scripts/stop-test-android.sh",
    "prestart-test:ios": "yarn patch-ios-build",
    "stop-test:ios": "./scripts/stop-test-ios.sh",
    "start-test:android": "./scripts/start-test-android.sh",
    "start-test:ios": "./scripts/start-test-ios.sh",
    "test:android": "yarn stop-test:android && yarn start-test:android",
    "test:ios": "yarn stop-test:ios && yarn start-test:ios",
    "patch-ios-build": "./scripts/patch-ios-build.sh",
    "pods": "yarn pods-install || yarn pods-update",
    "pods-install": "./scripts/pods-install.sh",
    "pods-update": "./scripts/pods-update.sh",
    "prebuild": "expo prebuild",
    "prebuild:ios": "yarn patch-ios-build",
    "build:ios": "./scripts/build-ios.sh",
    "build:android": "./scripts/build-android.sh",
    "build:ts": "tsc --noEmit",
    "lint": "eslint src playertesting tests --ext .ts,.tsx,.js,.jsx --quiet",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-tvos/config-tv": "^0.1.1",
    "cavy": "^4.0.2",
    "expo": "~54.0.34",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.9",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "npm:react-native-tvos@0.81.5-0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-uuid": "^2.0.1"
  },
  "devDependencies": {
    "@expo/config-types": "^54.0.10",
    "@babel/core": "^7.28.0",
    "@expo/cli": "^0.24.24",
    "@react-native-community/cli": "latest",
    "@react-native/metro-config": "0.81.5",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.0",
    "cavy-cli": "github:bitmovin-engineering/cavy-cli#a288754",
    "dotenv": "^17.2.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.1",
    "patch-package": "^8.0.1",
    "pod-install": "^0.3.10",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "resolutions": {
    "react-native": "npm:react-native-tvos@0.81.5-0"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "bitmovin-player-react-native",
          "@react-native-tvos/config-tv"
        ]
      }
    },
    "autolinking": {
      "nativeModulesDir": ".."
    }
  }
}
