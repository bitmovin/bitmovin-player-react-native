{
  "name": "integration-test",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "yarn test:ios && yarn test:android",
    "test:ios": "yarn start-test:ios",
    "test:android": "yarn start-test:android",
    "start-test:ios": "yarn prebuild && cavy run-ios --spec ./index.test.js",
    "start-test:android": "yarn prebuild && cavy run-android --spec ./index.test.js",
    "prebuild": "expo prebuild",
    "bootstrap": "yarn && yarn prebuild && yarn pods",
    "pods": "yarn pods-install || yarn pods-update",
    "pods-install": "[ \"$(uname)\" != Darwin ] || yarn pod-install",
    "pods-update": "[ \"$(uname)\" != Darwin ] || cd ios && pod update --silent",
    "build:ios": "xcodebuild -workspace ios/integration_test.xcworkspace -scheme integration_test -configuration Debug -destination 'generic/platform=iOS Simulator' -quiet | xcbeautify -qq --disable-logging",
    "build:android": "cd android && ./gradlew assembleDebug --quiet --console=plain --warning-mode=none",
    "build:ts": "tsc --noEmit",
    "lint": "eslint src playertesting tests --ext .ts,.tsx,.js,.jsx --quiet",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~51.0.31",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "npm:react-native-tvos@0.79.5-0",
    "cavy": "^4.0.2",
    "react-native-uuid": "^2.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.70.6",
    "cavy-cli": "^3.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "dotenv": "^17.2.0",
    "typescript": "^5.1.3",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.1",
    "pod-install": "^0.3.10",
    "prettier": "^3.6.2"
  },
  "resolutions": {
    "react-native": "npm:react-native-tvos@0.79.5-0"
  }
}
